# Supabase
DATABASE_URL="postgres://...:6543/postgres?pgbouncer=true"   # pooler transaction (runtime)
DIRECT_URL="postgres://...:5432/postgres"                     # directo (migraciones)

# Odoo (JSON-RPC)
ODOO_URL="https://tuempresa.odoo.com"
ODOO_DB="tuempresa"
ODOO_USERNAME="vos@tuempresa.com"
ODOO_API_KEY="xxxxxxxxxxxxxxxx"

# better-auth + Google OAuth
BETTER_AUTH_SECRET=""                  # generar: openssl rand -base64 32
# OJO: en producción (Vercel) debe ser el dominio real, NO localhost.
# Si queda en localhost, better-auth rechaza el login con "Invalid origin".
BETTER_AUTH_URL="http://localhost:3000"   # prod: https://quincena.bimeg.com
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
ALLOWED_EMAILS="vos@bimeg.com.ar,otro@bimeg.com.ar"
